# HAPI Validator local cache (large binary, downloaded on demand)
.hapi-cache/

# Terminology cache files (proprietary/licensed — must be built locally)
*.cache

# Terminology package sources (users need to fetch from vendor sites per licensing)
tx-server-build/loinc-src/
tx-server-build/snomed-src/
tx-server-build/terminology/fhir-server/

# Cloned fhirserver source (not part of this repo, cloned via setup script)
tx-server-build/fhirserver/

# Build logs
tx-server-build/*.log
tx-server-build/build_*.log

# LOINC/SNOMED/JP source zip and extracted files (users provide per licensing)
tx-server-build/loinc-src/
tx-server-build/snomed-src/
tx-server-build/terminology/jp-core/
tx-server-build/terminology/*.cache
# LB ベンチマーク用に copy された 2 番目の terminology dir (docs/benchmarks.md 参照)
tx-server-build/terminology-2/
# LOINC/SNOMED の入手済み zip (ユーザーが自分で loinc.org / UMLS から DL するもの)
tx-server-build/Loinc_*.zip
tx-server-build/SnomedCT_*.zip
tx-server-build/*.zip

# Validation input/output data (potentially patient data)
fhir_r4/
fhir_r4_sample/
fhir_r4_sample_*/
logs/

# 検証結果の raw NDJSON (数百 MB 〜 数 GB、meta.json と summary.md は commit)
validation-results/**/raw/*.ndjson
validation-results/**/raw/*.failed.ndjson

# JP Core / JP-CLINS package files (fetched via setup script)
jp_core/

# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]

# Editors
.vscode/
.idea/
*.swp

# Session resumption prompt (local, not for public repo)
.resume-prompt.md

# MHLW ICD-10 raw source と生成物 (user が個別 DL + build script で生成、tx-server-build/ 配下は全て build 生成物)
tx-server-build/mhlw-icd10-src/
